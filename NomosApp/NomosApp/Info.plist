<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Nomos</string>
    <key>CFBundleDisplayName</key>
    <string>Nomos</string>
    <!-- Hardcoded (not $(EXECUTABLE_NAME) / $(PRODUCT_BUNDLE_PACKAGE_TYPE))
         because Xcode 26's plist preprocessor was dropping these keys when
         the variable substitution didn't resolve, which made CoreDevice
         reject device installs with "missing CFBundleExecutable". -->
    <key>CFBundleExecutable</key>
    <string>NomosApp</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleIdentifier</key>
    <string>com.nomos.app</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UILaunchScreen</key>
    <dict/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>NSAppTransportSecurity</key>
    <dict>
        <!-- Allow localhost + LAN HTTP for development; remove before App Store submission -->
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
    <!-- Required on iOS 14+ to reach the dev server on the LAN (a.k.a. Bonjour / local network). -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>Nomos connects to your local Nomos development server to sync your portfolio.</string>
</dict>
</plist>
